<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox layoutX="20.0" layoutY="18.0" prefHeight="0.0" prefWidth="214.0" spacing="10" styleClass="container" stylesheets="@../Styles/Theme.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.diego.arbolbinario.Controller.ArchivoController">

    <TextField fx:id="txtResultado" promptText="Resultado:" styleClass="tree-node-label" />
    <Button fx:id="btnCargar" styleClass="boton-estilo" mnemonicParsing="false" onMouseClicked="#cargarArchivo" prefHeight="25.0" prefWidth="74.0" text="Cargar TXT" />
    <Button fx:id="btnGuardar" styleClass="boton-estilo" mnemonicParsing="false" onMouseClicked="#guardarArchivo" prefHeight="25.0" prefWidth="74.0" text="Guardar TXT" />
    <Button fx:id="btnRegresar" onMouseClicked="#regresar" styleClass="boton-estilo" mnemonicParsing="false" text="↩️" />
</VBox>
