<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="540.0" prefWidth="800.0" styleClass="root" stylesheets="@../Styles/Theme.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.diego.arbolbinario.Controller.BinarioController">
    <children>

        <Pane fx:id="overlay" prefHeight="540.0" prefWidth="800.0" />

        <Pane fx:id="contenedor" prefHeight="540.0" prefWidth="800.0">
            <children>
                <VBox layoutX="15.0" layoutY="14.0" prefHeight="200.0" prefWidth="200.0" styleClass="container">
                    <TextField fx:id="txtNodo" promptText="Nodo" styleClass="tree-node-label" />
                    <Button fx:id="btnIngresar" onMouseClicked="#ingNodo" styleClass="boton-estilo" text="Ingresar Nodo" />
                    <TextField fx:id="txtBuscar" promptText="Buscar nodo" styleClass="tree-node-label" />
                    <Button fx:id="btnBuscar" onMouseClicked="#buscarNodo" styleClass="boton-estilo" text="Buscar Nodo" />
                    <TextField fx:id="txtEliminar" promptText="Eliminar nodo" styleClass="tree-node-label" />
                    <Button fx:id="btnEliminar" onMouseClicked="#eliminarNodo" styleClass="boton-estilo" text="Eliminar Nodo" />

                          <TextField fx:id="txtResultado" promptText="Resultado:" styleClass="tree-node-label" />

                          <Button fx:id="btnPreOrden" onMouseClicked="#preOrden" styleClass="boton-estilo" text="PreOrden" />
