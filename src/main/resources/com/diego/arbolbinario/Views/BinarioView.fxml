                    <Button fx:id="btnCargar" mnemonicParsing="false" onMouseClicked="#cargarArchivo" prefHeight="25.0" prefWidth="74.0" styleClass="boton-estilo" text="Cargar TXT" />
                    <Button fx:id="btnGuardar" mnemonicParsing="false" onMouseClicked="#guardarArchivo" prefHeight="25.0" prefWidth="74.0" styleClass="boton-estilo" text="Guardar TXT" />

                </VBox>


                <Pane fx:id="treePane" layoutX="220.0" layoutY="10.0" prefHeight="520.0" prefWidth="566.0" />

            </children>
        </Pane>

    </children>
</AnchorPane>
